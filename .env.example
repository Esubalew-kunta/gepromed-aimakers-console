# ─────────────────────────────────────────────────────────────
# Gepromed AI Console — Environment variables
#
# The app is designed to DEPLOY AND DEMO even if every value below
# is left blank. Safe demo fallbacks are baked in. Set these in
# Render for a hardened, branded demo.
# ─────────────────────────────────────────────────────────────

# ── Required (recommended) ──────────────────────────────────
# Secret used to sign the demo session cookie. Any long random string.
# If blank, a built-in demo secret is used (fine for a private demo).
NEXTAUTH_SECRET=

# Public URL of the deployment. On Render this is your service URL,
# e.g. https://gepromed-ai-console.onrender.com
# If blank, the app infers the URL from the incoming request.
NEXTAUTH_URL=

# Base URL used for absolute links / health checks. Usually same as NEXTAUTH_URL.
APP_BASE_URL=

# ── Demo login accounts ─────────────────────────────────────
# These define who can log in. Blank values fall back to the
# documented demo credentials (see README).
DEFAULT_ADMIN_EMAIL=admin@aimakers.ai
DEFAULT_ADMIN_PASSWORD=

DEMO_GEPROMED_EMAIL=demo@gepromed.com
DEMO_GEPROMED_PASSWORD=

DEMO_MANAGER_EMAIL=manager@gepromed.com
DEMO_MANAGER_PASSWORD=

# ─────────────────────────────────────────────────────────────
# Supabase — shared backend (see IMPLEMENTATION_PLAN.md).
# Blank = offline DEMO MODE (seeded data). Set these to go live.
# The SaaS server uses the SERVICE_ROLE key (bypasses RLS); never
# expose service_role in any browser/frontend bundle.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Claude API — powers live skill runs (Phase 3). Blank = deterministic mock.
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────
# Optional / future integrations — NOT required for the demo.
# Leaving these blank keeps the app in fully-mocked DEMO MODE.
# ─────────────────────────────────────────────────────────────
DATABASE_URL=
OPENAI_API_KEY=
N8N_WEBHOOK_SECRET=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LMS_API_URL=
LMS_API_KEY=
