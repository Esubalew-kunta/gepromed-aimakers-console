{
  "name": "Gepromed · Confirm + LMS handoff",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "gepromed-lead-updated",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "b1111111-1111-4111-8111-111111111111",
      "name": "Supabase · lead updated",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 0],
      "webhookId": "gepromed-lead-updated"
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "loose", "version": 2 },
          "conditions": [
            {
              "id": "c-now",
              "leftValue": "={{ $json.body.record.stage }}",
              "rightValue": "confirmed",
              "operator": { "type": "string", "operation": "equals" }
            },
            {
              "id": "c-was",
              "leftValue": "={{ $json.body.old_record.stage }}",
              "rightValue": "confirmed",
              "operator": { "type": "string", "operation": "notEquals" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "b2222222-2222-4222-8222-222222222222",
      "name": "Just confirmed?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [220, 0],
      "notes": "Fires only on the lead to confirmed transition (Supabase sends every UPDATE)."
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://aablleekwyjqdxsscyeo.supabase.co/rest/v1/rpc/log_email_once",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "Content-Type", "value": "application/json" }]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"p_lead\": \"{{ $json.body.record.id }}\",\n  \"p_template\": \"confirmation\",\n  \"p_to\": \"{{ $json.body.record.email }}\",\n  \"p_daily\": false\n}",
        "options": {}
      },
      "id": "b3333333-3333-4333-8333-333333333333",
      "name": "Idempotency gate (log_email_once)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 0],
      "credentials": {
        "httpHeaderAuth": { "id": "REPLACE_WITH_SUPABASE_CRED", "name": "Supabase apikey" }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "loose", "version": 2 },
          "conditions": [
            {
              "id": "cond-send",
              "leftValue": "={{ $json.send }}",
              "rightValue": "",
              "operator": { "type": "boolean", "operation": "true", "singleValue": true }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "b4444444-4444-4444-8444-444444444444",
